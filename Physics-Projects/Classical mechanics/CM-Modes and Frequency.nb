            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Context", "[", "#", "]"}], "===", "\"\<System`\>\""}],
               "&&", 
              RowBox[{"MemberQ", "[", 
               RowBox[{
                RowBox[{"{", "t", "}"}], ",", "#"}], "]"}]}], "&"}], 
            ")"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Set", " ", "global", " ", "assumptions", " ", "to", " ", "avoid", " ",
          "Conjugate", " ", "issues"}], "*)"}], 
       RowBox[{"$Assumptions", "=", 
        RowBox[{"And", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Element", "[", 
             RowBox[{"#", ",", "Reals"}], "]"}], "&"}], "/@", 
           RowBox[{"Join", "[", 
            RowBox[{"q", ",", "realSymbols"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Solve", " ", "the", " ", "symbolic", " ", "generalized", " ", 
         "eigenvalue", " ", "problem"}], "*)"}], 
       RowBox[{"eigensystem", "=", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"{", 
          RowBox[{"K2", ",", "M2"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Extract", " ", "square", " ", "roots", " ", "of", " ", "eigenvalues",
          " ", "as", " ", "natural", " ", "frequencies"}], "*)"}], 
       RowBox[{"freqs", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"Simplify", "[", 
          RowBox[{"eigensystem", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pomega", "=", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Subscript", "[", 
             RowBox[{
              RowBox[{"Symbol", "[", "\"\<\[Omega]\>\"", "]"}], ",", "i"}], 
             "]"}], "->", 
            RowBox[{"freqs", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "freqs", "]"}]}], "}"}]}], "]"}], "//", 
         "TableForm"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Define", " ", "M"}], "-", 
         RowBox[{"normalization", " ", "function", " ", 
          RowBox[{"(", 
           RowBox[{"no", " ", "FullSimplify", " ", "for", " ", "speed"}], 
           ")"}]}]}], "*)"}], 
       RowBox[{
        RowBox[{
         RowBox[{"normalizeWithM", "[", "M_", "]"}], "[", "v_", "]"}], ":=", 
