Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Small", "-", "Oscillations", "-", 
    RowBox[{"Resonant", " ", "frequency", " ", "and", " ", "modes"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SOFM", "[", 
     RowBox[{"T_List", ",", "V_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "t", ",", "q", ",", "M", ",", "K", ",", "eigensystem", ",", "freqs", ",",
         "rawModes", ",", "normalizeWithM", ",", "modes", ",", "T2", ",", 
        "V2", ",", "realSymbols", ",", "M2", ",", "K2", ",", "pomega"}], 
       "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Automatically", " ", "detect", " ", "time", " ", "variable"}],
        "*)"}], 
      RowBox[{
       RowBox[{"t", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"T", ",", "V"}], "}"}], ",", 
             RowBox[{
              RowBox[{"_", "[", "arg_", "]"}], ":>", "arg"}], ",", 
             "Infinity"}], "]"}], "//", "Flatten"}], "//", 
          "DeleteDuplicates"}], "//", "First"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Automatically", " ", "extract", " ", "generalized", " ", 
         "coordinates"}], "*)"}], 
       RowBox[{"q", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"T", ",", "V"}], "}"}], ",", 
             RowBox[{
              RowBox[{"f_Symbol", "[", "t", "]"}], ":>", 
              RowBox[{"f", "[", "t", "]"}]}], ",", "Infinity"}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"f", "[", "t", "]"}], " ", "form"}], "*)"}], 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"T", ",", "V"}], "}"}], ",", 
             RowBox[{
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"f_Symbol", "[", "t", "]"}], ",", "t"}], "]"}], ":>", 
              RowBox[{"f", "[", "t", "]"}]}], ",", "Infinity"}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"f", "[", "t", "]"}], ",", "t"}], "]"}], " ", "form"}],
             "*)"}], 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"T", ",", "V"}], "}"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Derivative", "[", "1", "]"}], "[", "f_", "]"}], "[", 
               "t", "]"}], ":>", 
              RowBox[{"f", "[", "t", "]"}]}], ",", "Infinity"}], "]"}]}], 
          "   ", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{"f", "'"}], "[", "t", "]"}], " ", "form"}], "*)"}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Pre", "-", 
         RowBox[{
         "simplify", " ", "total", " ", "kinetic", " ", "and", " ", 
          "potential", " ", "energies"}]}], "*)"}], 
       RowBox[{"T2", "=", 
        RowBox[{"Together", "@", 
         RowBox[{"TrigReduce", "@", 
          RowBox[{"Simplify", "@", 
           RowBox[{"Total", "[", "T", "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"V2", "=", 
        RowBox[{"Together", "@", 
         RowBox[{"TrigReduce", "@", 
          RowBox[{"Simplify", "@", 
           RowBox[{"Total", "[", "V", "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Build", " ", "mass", " ", 
         RowBox[{"(", "M", ")"}], " ", "and", " ", "stiffness", " ", 
         RowBox[{"(", "K", ")"}], " ", "matrices", " ", "symbolically"}], 
        "*)"}], 
       RowBox[{"M", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{"T2", ",", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"q", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", "t"}], "]"}], ",", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"q", "[", 
               RowBox[{"[", "j", "]"}], "]"}], ",", "t"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "q", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", 
            RowBox[{"Length", "[", "q", "]"}]}], "}"}]}], "]"}]}], ";", 
       RowBox[{"M2", "=", 
        RowBox[{
         RowBox[{"Simplify", "[", 
          RowBox[{"M", ",", 
           RowBox[{"Trig", "->", "True"}]}], "]"}], "/.", 
         RowBox[{"Thread", "[", 
          RowBox[{"q", "->", "0"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"K", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{"V2", ",", 
            RowBox[{"q", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"q", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "q", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", 
            RowBox[{"Length", "[", "q", "]"}]}], "}"}]}], "]"}]}], ";", 
       RowBox[{"K2", "=", 
        RowBox[{
         RowBox[{"Simplify", "[", 
