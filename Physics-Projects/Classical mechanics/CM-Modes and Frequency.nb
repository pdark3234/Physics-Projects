          RowBox[{"Union", "@", 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"T", ",", "V"}], "}"}], ",", 
             RowBox[{"s_Symbol", "/;", 
