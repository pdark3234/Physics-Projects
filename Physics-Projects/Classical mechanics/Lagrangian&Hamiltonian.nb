Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ELH", "[", 
    RowBox[{"T_", ",", "V_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t", ",", "q", ",", "dqdt", ",", "L", ",", "dLdq", ",", "dLdqd", ",", 
       "ddLdqd", ",", "eqns", ",", "baseNames", ",", "pVars", ",", "momEqns", 
       ",", "sol", ",", "H", ",", "Hcanonical", ",", "T2", ",", "V2", ",", 
       "labels", ",", "NiceForm"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Infer", " ", "time", " ", "variable", " ", "t"}], "*)"}], 
     RowBox[{
      RowBox[{"t", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", "V"}], "}"}], ",", 
            RowBox[{
             RowBox[{"_", "[", "arg_", "]"}], ":>", "arg"}], ",", 
            "\[Infinity]"}], "]"}], "//", "Flatten"}], "//", 
         "DeleteDuplicates"}], "//", "First"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Extract", " ", "generalized", " ", "coordinates", " ", "from", " ", 
        "multiple", " ", "forms"}], "*)"}], 
      RowBox[{"q", "=", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", "V"}], "}"}], ",", 
            RowBox[{
             RowBox[{"f_Symbol", "[", "t", "]"}], ":>", 
             RowBox[{"f", "[", "t", "]"}]}], ",", "\[Infinity]"}], "]"}], ",", 
          RowBox[{"(*", 
           RowBox[{"direct", " ", "use"}], "*)"}], 
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", "V"}], "}"}], ",", 
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"f_Symbol", "[", "t", "]"}], ",", "t"}], "]"}], ":>", 
             RowBox[{"f", "[", "t", "]"}]}], ",", "\[Infinity]"}], "]"}], ",", 
          RowBox[{"(*", 
           RowBox[{"D", " ", "form"}], "*)"}], 
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", "V"}], "}"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Derivative", "[", "1", "]"}], "[", "f_", "]"}], "[", 
              "t", "]"}], ":>", 
             RowBox[{"f", "[", "t", "]"}]}], ",", "\[Infinity]"}], "]"}]}], 
         "                    ", 
         RowBox[{"(*", 
          RowBox[{"prime", " ", "form"}], "*)"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", "Velocities", "*)"}], 
      RowBox[{"dqdt", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"#", ",", "t"}], "]"}], "&"}], "/@", "q"}]}], ";", 
      RowBox[{"T2", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"ListQ", "[", "T", "]"}], ",", 
         RowBox[{"Total", "[", "T", "]"}], ",", "T"}], "]"}]}], ";", "\n", 
      RowBox[{"V2", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"ListQ", "[", "V", "]"}], ",", 
         RowBox[{"Total", "[", "V", "]"}], ",", "V"}], "]"}]}], ";", 
      RowBox[{"(*", "Visual", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"NiceForm", "[", "expr_", "]"}], ":=", 
       RowBox[{"expr", "//.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Derivative", "[", "2", "]"}], "[", "q_Symbol", "]"}], "[",
             "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{
             RowBox[{"Overscript", "[", 
              RowBox[{"q", ",", 
               RowBox[{"Style", "[", 
                RowBox[{"\"\<\[DoubleDot]\>\"", ",", 
                 RowBox[{"FontSize", "->", "14"}]}], "]"}]}], "\n", "]"}], 
             ",", "\"\<\>\""}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Derivative", "[", "2", "]"}], "[", 
             RowBox[{"Subscript", "[", 
              RowBox[{"q_", ",", "i_"}], "]"}], "]"}], "[", "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{
             RowBox[{"Overscript", "[", 
              RowBox[{"q", ",", 
               RowBox[{"Style", "[", 
                RowBox[{"\"\<\[DoubleDot]\>\"", ",", "Bold"}], "]"}]}], "\n", 
              "]"}], ",", "i"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Derivative", "[", "1", "]"}], "[", "q_Symbol", "]"}], "[",
             "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{
             RowBox[{"Overscript", "[", 
              RowBox[{"q", ",", 
               RowBox[{"Style", "[", 
                RowBox[{"\"\<.\>\"", ",", 
                 RowBox[{"FontSize", "->", "14"}]}], "]"}]}], "]"}], 
             ",", "\"\<\>\""}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Derivative", "[", "1", "]"}], "[", 
             RowBox[{"Subscript", "[", 
              RowBox[{"q_", ",", "i_"}], "]"}], "]"}], "[", "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{
             RowBox[{"Overscript", "[", 
              RowBox[{"q", ",", "\"\<.\>\""}], "]"}], ",", "i"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"q_Symbol", "[", "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{"q", ",", "\"\<\>\""}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Subscript", "[", 
             RowBox[{"q_", ",", "i_"}], "]"}], "[", "t", "]"}], ":>", 
           RowBox[{"Subscript", "[", 
            RowBox[{"q", ",", "i"}], "]"}]}]}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", "Lagrangian", "*)"}], 
      RowBox[{"L", "=", 
       RowBox[{"T2", "-", "V2"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Partial", " ", "derivatives", " ", "for", " ", "EL", " ", 
        "equations"}], "*)"}], 
      RowBox[{"dLdqd", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"L", ",", "#"}], "]"}], "&"}], "/@", "dqdt"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dLdq", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"L", ",", "#"}], "]"}], "&"}], "/@", "q"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ddLdqd", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"#", ",", "t"}], "]"}], "&"}], "/@", "dLdqd"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Euler", "\[Dash]", 
        RowBox[{"Lagrange", " ", "equations"}]}], "*)"}], 
      RowBox[{"eqns", "=", 
       RowBox[{
        RowBox[{"Thread", "[", 
         RowBox[{
          RowBox[{"ddLdqd", "-", "dLdq"}], "==", "0"}], "]"}], "//", 
        "Simplify"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"labels", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\"\<eq(for \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"q", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}], "<>", "\"\<)\>\""}], "->", 
          RowBox[{"eqns", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "q", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Momentum", " ", "variable", " ", "names"}], "*)"}], 
      RowBox[{"baseNames", "=", 
       RowBox[{"q", "/.", " ", 
        RowBox[{
         RowBox[{"s_Symbol", "[", "t", "]"}], ":>", 
         RowBox[{"SymbolName", "[", "s", "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pVars", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{
            RowBox[{"Symbol", "[", "\"\<p\>\"", "]"}], ",", 
            RowBox[{"baseNames", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "q", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Momentum", " ", "equations"}], "*)"}], 
      RowBox[{"momEqns", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"pVars", "==", "dLdqd"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", "Hamiltonian", "*)"}], 
      RowBox[{"H", "=", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"dLdqd", "*", "dqdt"}], "]"}], "-", "L"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Solve", " ", "for", " ", "velocities", " ", "in", " ", "terms", " ", 
        "of", " ", "momenta"}], "*)"}], 
      RowBox[{"sol", "=", 
       RowBox[{"Solve", "[", 
        RowBox[{"momEqns", ",", "dqdt"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Substitute", " ", "to", " ", "get", " ", "H", 
        RowBox[{"(", 
         RowBox[{"p", ",", "q"}], ")"}]}], "*)"}], 
      RowBox[{"Hcanonical", "=", 
       RowBox[{"Simplify", "[", 
        RowBox[{"H", "/.", " ", 
         RowBox[{"First", "[", "sol", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", "Output", "*)"}], 
      RowBox[{"TabView", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Lagrangian\>\"", "->", 
          RowBox[{"NiceForm", "[", "L", "]"}]}], ",", 
         RowBox[{"\"\<Euler-Lagrange Equations\>\"", "->", 
          RowBox[{"TableForm", "[", 
           RowBox[{"NiceForm", "[", "labels", "]"}], "]"}]}], ",", 
         RowBox[{"\"\<Generalized Momenta\>\"", "->", 
          RowBox[{"TableForm", "[", 
           RowBox[{"Thread", "[", 
            RowBox[{"NiceForm", "[", 
             RowBox[{"pVars", "->", "dLdqd"}], "]"}], "]"}], "]"}]}], ",", 
         RowBox[{"\"\<Hamiltonian\>\"", "->", 
          RowBox[{"NiceForm", "[", "Hcanonical", "]"}]}]}], "|>"}], "]"}]}]}],
     "\n", "]"}]}], "\n"}]], "Input",
