       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", 
         FractionBox[
          RowBox[{"5", " ", "Pi"}], "2"]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "10"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Tan[z]\>\"", ",", 
          "\"\<Sqrt[(\!\(\*FractionBox[\(z0\), \
\(z\)]\)\!\(\*SuperscriptBox[\()\), \(2\)]\)-1]\>\""}], "}"}]}], ",", 
