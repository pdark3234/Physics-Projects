            RowBox[{"{", 
             RowBox[{"n", ",", "0", ",", 
              RowBox[{"5", 
               FractionBox["Pi", "2"]}], ",", 
              FractionBox["Pi", "2"]}], "}"}]}], "]"}], ",", "None"}], 
         "}"}]}], ",", 
       RowBox[{"GridLinesStyle", "->", 
        RowBox[{"Directive", "[", 
