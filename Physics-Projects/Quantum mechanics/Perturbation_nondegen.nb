          RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sumIndices", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"#", ",", "1", ",", "\[Infinity]"}], "}"}], "&"}], ",", 
          "m"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"neqCondition", "=", 
        RowBox[{"Not", "[", 
         RowBox[{"And", "@@", 
          RowBox[{"Thread", "[", 
           RowBox[{"m", "==", "n"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"E2", "=", 
        RowBox[{
         RowBox[{"Inactive", "[", "Sum", "]"}], "[", 
         RowBox[{"term", ",", 
          RowBox[{"Sequence", "@@", "sumIndices"}], ",", "neqCondition"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
