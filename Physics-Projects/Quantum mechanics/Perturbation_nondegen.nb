       RowBox[{"integrand2", "=", 
        RowBox[{
         RowBox[{"Conjugate", "[", "\[Psi]m", "]"}], " ", "H", " ", 
         "\[Psi]n"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"matrixElem", "=", 
        RowBox[{"Integrate", "[", 
