          RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"delta", "=", 
        RowBox[{
         RowBox[{"E0", "@@", "n"}], "-", 
