     "\[Psi]_", ",", "H_", ",", "bounds_List", ",", "n_List", ",", "m_List", ",",
       "E0_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "E1", ",", "E2", ",", "psi1", ",", "\[Psi]n", ",", "\[Psi]m", ",", 
        "integrand1", ",", "integrand2", ",", "matrixElem", ",", "delta", ",",
         "term", ",", "sumIndices", ",", "neqCondition", ",", "allExprs", ",",
         "symbols", ",", "assumptions", ",", "quantumAssumptions"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Evaluate", " ", "\[Psi]", " ", "at", " ", "n", " ", "and", " ", "m"}],
        "*)"}], 
      RowBox[{
       RowBox[{"\[Psi]n", "=", 
        RowBox[{"\[Psi]", "@@", "n"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Psi]m", "=", 
        RowBox[{"\[Psi]", "@@", "m"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Gather", " ", "all", " ", "symbolic", " ", "expressions", " ", "to", 
         " ", "scan"}], "*)"}], 
       RowBox[{"allExprs", "=", 
        RowBox[{"{", 
         RowBox[{"\[Psi]n", ",", "\[Psi]m", ",", "H", ",", 
          RowBox[{"E0", "@@", "n"}], ",", 
          RowBox[{"E0", "@@", "m"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Extract", " ", "all", " ", "used", " ", "symbols", " ", 
         RowBox[{"(", 
          RowBox[{"non", "-", 
           RowBox[{"System", " ", "symbols"}]}], ")"}]}], "*)"}], 
       RowBox[{"symbols", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Cases", "[", 
          RowBox[{"allExprs", ",", 
           RowBox[{"s_Symbol", "/;", 
            RowBox[{
             RowBox[{"Context", "[", "s", "]"}], "=!=", "\"\<System`\>\""}]}],
            ",", "\[Infinity]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"General", " ", 
         RowBox[{"assumptions", ":", 
          RowBox[{
          "all", " ", "symbols", " ", "real", " ", "and", " ", 
           "positive"}]}]}], "*)"}], 
       RowBox[{"assumptions", "=", 
        RowBox[{"Thread", "[", 
         RowBox[{
          RowBox[{"symbols", "\[Element]", "Reals"}], "&&", 
          RowBox[{"symbols", ">", "0"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Quantum", " ", "number", " ", 
