        RowBox[{"And", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Element", "[", 
              RowBox[{"#", ",", "Integers"}], "]"}], "&&", 
             RowBox[{"#", ">", "0"}]}], "&"}], "/@", 
           RowBox[{"Join", "[", 
            RowBox[{"n", ",", "m"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
