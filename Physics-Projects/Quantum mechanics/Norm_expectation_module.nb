Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Psi", "[", "x_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", " ", 
      FractionBox[
       RowBox[{"m", " ", "\[Omega]"}], 
       RowBox[{"2", " ", "\[HBar]"}]]}], 
     SuperscriptBox["x", "2"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Quantummodule", "[", 
   RowBox[{
    RowBox[{"Psi", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}], "}"}], ",", 
    "0", ",", 
    RowBox[{"compute", "->", 
     RowBox[{"{", "\"\<<x>\>\"", "}"}]}], ",", 
    RowBox[{"inferPotential", "->", "True"}], ",", 
    RowBox[{"energy", "->", 
     RowBox[{
      FractionBox["1", "2"], "\[HBar]", " ", "\[Omega]"}]}]}], "]"}], "//", 
