Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "Quantummodule", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", "->", "\[HBar]"}], ",", 
      RowBox[{"mass", "->", "m"}], ",", 
      RowBox[{"compute", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<<x>\>\"", ",", "\"\<<p_x>\>\"", ",", "\"\<<T>\>\"", 
         ",", "\"\<<H>\>\""}], "}"}]}], ",", 
      RowBox[{"inferPotential", "->", "False"}], ",", 
      RowBox[{"energy", "->", "Automatic"}]}], "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Quantummodule", "[", 
   RowBox[{"Psi_", ",", "coords_List", ",", 
    RowBox[{"potential_", ":", "0"}], ",", 
    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"h", "=", 
       RowBox[{"OptionValue", "[", "h", "]"}]}], ",", 
      RowBox[{"m", "=", 
       RowBox[{"OptionValue", "[", "mass", "]"}]}], ",", 
      RowBox[{"toCompute", "=", 
       RowBox[{"OptionValue", "[", "compute", "]"}]}], ",", 
      RowBox[{"inferQ", "=", 
       RowBox[{"OptionValue", "[", "inferPotential", "]"}]}], ",", "ops", ",",
       "ynorm", ",", "norm", ",", "normConst", ",", "symbolsinPsi", ",", 
      "allSymbols", ",", "assumptions", ",", "results", ",", "inferredV", ",",
       "\[Psi]", ",", "laplacian", ",", "d\[CapitalPsi]t", ",", "timeDepQ", ",",
       "xvars", ",", "inferred", ",", "Vinternal", ",", "eVal"}], "}"}], ",", 
    RowBox[{
     RowBox[{"\[Psi]", "=", "Psi"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Vinternal", "=", "potential"}], ";", 
     RowBox[{"eVal", "=", 
      RowBox[{"OptionValue", "[", "energy", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Potential", " ", "inference", " ", "if", " ", "requested"}], 
      "*)"}], 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"inferQ", "&&", 
        RowBox[{"potential", "===", "0"}]}], ",", 
       RowBox[{
        RowBox[{"xvars", "=", 
         RowBox[{"First", "/@", "coords"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"timeDepQ", "=", 
         RowBox[{"Not", "@", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"\[Psi]", ",", "t"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"laplacian", "=", 
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{"\[Psi]", ",", 
              RowBox[{"{", 
               RowBox[{"#", ",", "2"}], "}"}]}], "]"}], "&"}], "/@", 
           "xvars"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{"timeDepQ", ",", 
          RowBox[{
           RowBox[{"d\[CapitalPsi]t", "=", 
            RowBox[{"D", "[", 
             RowBox[{"\[Psi]", ",", "t"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"inferred", "=", 
            RowBox[{"FullSimplify", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"I", " ", "h", " ", "d\[CapitalPsi]t"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"h", "^", "2"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"2", " ", "m"}], ")"}]}], ")"}], " ", 
                 "laplacian"}]}], ")"}], "/", "\[Psi]"}], "]"}]}], ";"}], ",", 
          RowBox[{
           RowBox[{"inferred", "=", 
            RowBox[{"FullSimplify", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"h", "^", "2"}], "/", 
                RowBox[{"(", 
                 RowBox[{"2", " ", "m"}], ")"}]}], ")"}], " ", 
              RowBox[{"laplacian", "/", "\[Psi]"}]}], "]"}]}], ";", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"eVal", "=!=", "Automatic"}], ",", 
             RowBox[{
              RowBox[{"inferred", "+=", "eVal"}], ";", "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               
               RowBox[{"\"\<Note: Using user-specified energy E = \>\"", ",", 
                "eVal"}], "]"}], ";"}]}], "]"}], ";"}]}], "\n", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Vinternal", "=", "inferred"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Build", " ", "operators", " ", "dynamically"}], "*)"}], 
     RowBox[{"ops", "=", 
      RowBox[{"Association", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"x", "=", 
            RowBox[{"coords", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ",", "xstr"}], "}"}], ",", 
         RowBox[{
          RowBox[{"xstr", "=", 
           RowBox[{"ToString", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ops", "[", 
            RowBox[{"\"\<<\>\"", "<>", "xstr", "<>", "\"\<>\>\""}], "]"}], "=", 
           RowBox[{"Function", "[", 
            RowBox[{"\[Psi]", ",", 
             RowBox[{"x", " ", "\[Psi]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ops", "[", 
            RowBox[{"\"\<<\>\"", "<>", "xstr", "<>", "\"\<^2>\>\""}], "]"}], "=", 
           RowBox[{"Function", "[", 
            RowBox[{"\[Psi]", ",", 
             RowBox[{
              RowBox[{"x", "^", "2"}], " ", "\[Psi]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ops", "[", 
            RowBox[{"\"\<<p_\>\"", "<>", "xstr", "<>", "\"\<>\>\""}], "]"}], "=", 
           RowBox[{"Function", "[", 
            RowBox[{"\[Psi]", ",", 
             RowBox[{
              RowBox[{"-", "I"}], " ", "h", " ", 
              RowBox[{"D", "[", 
               RowBox[{"\[Psi]", ",", "x"}], "]"}]}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ops", "[", 
            RowBox[{"\"\<<p_\>\"", "<>", "xstr", "<>", "\"\<^2>\>\""}], "]"}],
            "=", 
           RowBox[{"Function", "[", 
            RowBox[{"\[Psi]", ",", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"h", "^", "2"}]}], " ", 
              RowBox[{"D", "[", 
               RowBox[{"\[Psi]", ",", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}]}], "]"}]}], 
          ";"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "coords", "]"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ops", "[", "\"\<<T>\>\"", "]"}], "=", 
      RowBox[{"Function", "[", 
       RowBox[{"\[Psi]", ",", 
        RowBox[{"Total", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"h", "^", "2"}]}], "/", 
             RowBox[{"(", 
              RowBox[{"2", " ", "m"}], ")"}]}], " ", 
            RowBox[{"D", "[", 
             RowBox[{"\[Psi]", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"coords", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "2"}], "}"}]}], 
             "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "coords", "]"}]}], "}"}]}], "]"}]}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ops", "[", "\"\<<V>\>\"", "]"}], "=", 
      RowBox[{"Function", "[", 
       RowBox[{"\[Psi]", ",", 
        RowBox[{"Vinternal", " ", "\[Psi]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ops", "[", "\"\<<H>\>\"", "]"}], "=", 
      RowBox[{"Function", "[", 
       RowBox[{"\[Psi]", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"ops", "[", "\"\<<T>\>\"", "]"}], "[", "\[Psi]", "]"}], "+", 
         RowBox[{
          RowBox[{"ops", "[", "\"\<<V>\>\"", "]"}], "[", "\[Psi]", "]"}]}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", "Assumptions", "*)"}], 
     RowBox[{"symbolsinPsi", "=", 
      RowBox[{"DeleteDuplicates", "@", 
       RowBox[{"Cases", "[", 
        RowBox[{"\[Psi]", ",", "_Symbol", ",", "All"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"allSymbols", "=", 
      RowBox[{"Union", "[", 
       RowBox[{"symbolsinPsi", ",", 
        RowBox[{"First", "/@", "coords"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"assumptions", "=", 
      RowBox[{"And", "@@", 
       RowBox[{"Flatten", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Element", "[", 
             RowBox[{"#", ",", "Reals"}], "]"}], "&"}], "/@", "allSymbols"}], 
          ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Positive", "[", "#", "]"}], "&"}], "/@", 
           "allSymbols"}]}], "}"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", "Normalize", "*)"}], 
     RowBox[{"norm", "=", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", "\[Psi]", "]"}], " ", "\[Psi]"}], ",", 
        RowBox[{"Sequence", "@@", "coords"}], ",", 
        RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"normConst", "=", 
      RowBox[{"Assuming", "[", 
       RowBox[{"assumptions", ",", 
        RowBox[{"Simplify", "@", 
         RowBox[{"Refine", "[", 
          RowBox[{"1", "/", 
           RowBox[{"Sqrt", "[", "norm", "]"}]}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ynorm", "=", 
      RowBox[{"\[Psi]", "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"normConst", "^", "2"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Expectation", " ", "values"}], "*)"}], 
     RowBox[{"results", "=", 
      RowBox[{"Association", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"results", "[", "\"\<Normalization Constant\>\"", "]"}], "=", 
      "normConst"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"results", "[", "\"\<Potential\>\"", "]"}], "=", "Vinternal"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"KeyExistsQ", "[", 
          RowBox[{"ops", ",", "opID"}], "]"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"opApplied", ",", "integrand", ",", "expect"}], "}"}], ",", 
           RowBox[{
            RowBox[{"opApplied", "=", 
             RowBox[{
              RowBox[{"ops", "[", "opID", "]"}], "[", "ynorm", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"integrand", "=", 
             RowBox[{
              RowBox[{"Conjugate", "[", "ynorm", "]"}], " ", "opApplied"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"expect", "=", 
             RowBox[{"Integrate", "[", 
              RowBox[{"integrand", ",", 
               RowBox[{"Sequence", "@@", "coords"}], ",", 
               RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"results", "[", "opID", "]"}], "=", 
             RowBox[{"Assuming", "[", 
              RowBox[{"assumptions", ",", 
               RowBox[{"Simplify", "@", 
                RowBox[{"Refine", "[", "expect", "]"}]}]}], "]"}]}], ";"}]}], 
          "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"opID", ",", "toCompute"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"TabView", "[", "results", "]"}]}]}], "]"}]}], "\n"}], "Input",
