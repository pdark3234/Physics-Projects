       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "0", ",", "b"}], "}"}], ",", 
       RowBox[{"{", 
