Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(A\\), \\(\\\\ \\(0\\)\\)]\\)\"\>", "\[Rule]", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["L", "2"]}], "3"]}], ",", 
   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(A\\), \\(\\\\ \\(n\\)\\)]\\)\"\>", "\[Rule]", 
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["L", "2"]}], 
     RowBox[{
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["\[Pi]", "2"]}]]}], ",", 
   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(B\\), \\(n\\)]\\)\"\>", "\[Rule]", 
    "0"}], ",", 
   RowBox[{"\<\"SeriesInactive\"\>", "\[Rule]", 
    RowBox[{
     FractionBox[
      SuperscriptBox["L", "2"], "3"], "+", 
     TemplateBox[{
       FractionBox[
        RowBox[{"4", " ", 
          SuperscriptBox["L", "2"], " ", 
          RowBox[{"Cos", "[", 
            FractionBox[
             RowBox[{"n", " ", "\[Pi]", " ", 
               RowBox[{"(", 
                 RowBox[{"L", "+", "x"}], ")"}]}], "L"], "]"}]}], 
        RowBox[{
          SuperscriptBox["n", "2"], " ", 
          SuperscriptBox["\[Pi]", "2"]}]], "n", "1", "\[Infinity]"},
      "InactiveSum",
      DisplayFunction->(RowBox[{
         UnderoverscriptBox[
          StyleBox["\[Sum]", "Inactive"], 
          RowBox[{#2, "=", #3}], #4], #}]& ),
      InterpretationFunction->(RowBox[{
         RowBox[{"Inactive", "[", "Sum", "]"}], "[", 
         RowBox[{#, ",", 
           RowBox[{"{", 
             RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]}]}], 
  "\[RightAssociation]"}]], "Output",
