Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "FourierSeriesModule", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "FourierSeriesModule", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"IndexSymbol", "->", "n"}], ",", 
      RowBox[{"MaxSimplify", "->", "True"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"FourierSeriesModule", "[", 
   RowBox[{"f_", ",", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "a_", ",", "b_"}], "}"}], ",", 
    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"idx", "=", 
       RowBox[{"OptionValue", "[", "IndexSymbol", "]"}]}], ",", 
      RowBox[{"doSimplify", "=", 
       RowBox[{"OptionValue", "[", "MaxSimplify", "]"}]}], ",", "T", ",", 
      "\[Omega]", ",", "A0", ",", "an", ",", "bn", ",", "simpAssumps", ",", 
      "seriesExpr", ",", "replacementRules"}], "}"}], ",", 
    RowBox[{
     RowBox[{"T", "=", 
      RowBox[{"b", "-", "a"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Omega]", "=", 
      RowBox[{"2", " ", 
       RowBox[{"Pi", "/", "T"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", "Coefficients", "*)"}], 
     RowBox[{"A0", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "T"}], ")"}], " ", 
       RowBox[{"Integrate", "[", 
        RowBox[{"f", ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"an", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "T"}], ")"}], " ", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"f", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"idx", "*", "\[Omega]", "*", 
            RowBox[{"(", 
             RowBox[{"x", "-", "a"}], ")"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bn", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "T"}], ")"}], " ", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"f", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"idx", "*", "\[Omega]", "*", 
            RowBox[{"(", 
             RowBox[{"x", "-", "a"}], ")"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"simpAssumps", "=", 
      RowBox[{"Element", "[", 
       RowBox[{"idx", ",", "Integers"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"replacementRules", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"Pi", " ", "idx"}], "]"}], ":>", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", "idx"}]}], ",", 
        RowBox[{
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", " ", "idx"}], "]"}], ":>", "0"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"TrueQ", "[", "doSimplify", "]"}], ",", 
       RowBox[{
        RowBox[{"A0", "=", 
         RowBox[{
          RowBox[{"Simplify", "[", 
           RowBox[{"A0", ",", 
            RowBox[{"Assumptions", "->", "simpAssumps"}]}], "]"}], "/.", " ", 
          "replacementRules"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"an", "=", 
         RowBox[{
          RowBox[{"Simplify", "[", 
           RowBox[{"an", ",", 
            RowBox[{"Assumptions", "->", "simpAssumps"}]}], "]"}], "/.", " ", 
          "replacementRules"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"bn", "=", 
         RowBox[{
          RowBox[{"Simplify", "[", 
           RowBox[{"bn", ",", 
            RowBox[{"Assumptions", "->", "simpAssumps"}]}], "]"}], "/.", " ", 
          "replacementRules"}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Build", " ", 
       RowBox[{"series", ":", 
        RowBox[{
        "omit", " ", "terms", " ", "if", " ", "coeffs", " ", "are", " ", 
         "0"}]}]}], "*)"}], 
     RowBox[{"seriesExpr", "=", 
      RowBox[{"Inactivate", "[", 
       RowBox[{
        RowBox[{"A0", "/", "2"}], ",", "Sum"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"an", "=!=", "0"}], ",", 
       RowBox[{
        RowBox[{"seriesExpr", "+=", 
         RowBox[{"Inactivate", "[", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"an", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"idx", "*", "\[Omega]", "*", 
                RowBox[{"(", 
                 RowBox[{"x", "-", "a"}], ")"}]}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"idx", ",", "1", ",", "Infinity"}], "}"}]}], "]"}], ",",
            "Sum"}], "]"}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"bn", "=!=", "0"}], ",", 
       RowBox[{
        RowBox[{"seriesExpr", "+=", 
         RowBox[{"Inactivate", "[", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"bn", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"idx", "*", "\[Omega]", "*", 
                RowBox[{"(", 
                 RowBox[{"x", "-", "a"}], ")"}]}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"idx", ",", "1", ",", "Infinity"}], "}"}]}], "]"}], ",",
            "Sum"}], "]"}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<\!\(\*SubscriptBox[\(A\), \(\\\ \(0\)\)]\)\>\"", "->", 
        "A0"}], ",", 
       RowBox[{"\"\<\!\(\*SubscriptBox[\(A\), \(\\\ \(n\)\)]\)\>\"", "->", 
        "an"}], ",", 
       RowBox[{"\"\<\!\(\*SubscriptBox[\(B\), \(n\)]\)\>\"", "->", "bn"}], ",", 
       RowBox[{"\"\<SeriesInactive\>\"", "->", "seriesExpr"}]}], "|>"}]}]}], 
   "]"}]}], "\n", 
 RowBox[{" "}]}], "Input",
 CellChangeTimes->{{3.9680413150347576`*^9, 3.9680413656787815`*^9}, {
  3.968042119444643*^9, 3.968042131313471*^9}},
