   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(A\\), \\(\\\\ \\(0\\)\\)]\\)\"\>", "\[Rule]",
     "0"}], ",", 
   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(A\\), \\(\\\\ \\(n\\)\\)]\\)\"\>", "\[Rule]",
     "0"}], ",", 
   RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(B\\), \\(n\\)]\\)\"\>", "\[Rule]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", "L"}], 
      RowBox[{"n", " ", "\[Pi]"}]]}]}], ",", 
