Cell[BoxData[
 RowBox[{
  RowBox[{"FourierSeriesModule", "[", 
   RowBox[{
    RowBox[{"x", "^", "2"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "L"}], ",", "L"}], "}"}]}], "]"}], "\n"}]], "Input",
