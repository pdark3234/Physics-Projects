Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "odeSolver", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "odeSolver", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"\"\<Method\>\"", "->", "\"\<Euler\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"odeSolver", "[", 
   RowBox[{"f_", ",", "X0_List", ",", 
    RowBox[{"tf_", "?", "NumericQ"}], ",", 
    RowBox[{"n_Integer", "?", "Positive"}], ",", 
    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "h", ",", "datalist", ",", "prev", ",", "next", ",", "r1", ",", "r2", ",",
       "r3", ",", "r4", ",", "method"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{"step", " ", "size"}], "*)"}], 
    RowBox[{
     RowBox[{"h", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"tf", "-", 
          RowBox[{"X0", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", "n"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"normalize", "/", "tolerate"}], " ", "various", " ", "method", 
       " ", "names"}], "*)"}], 
     RowBox[{"method", "=", 
      RowBox[{"ToLowerCase", "@", 
       RowBox[{"ToString", "@", 
        RowBox[{"OptionValue", "[", "\"\<Method\>\"", "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"datalist", "=", 
        RowBox[{"{", "X0", "}"}]}], ",", 
       RowBox[{"(*", "start", "*)"}], 
       RowBox[{
        RowBox[{"Length", "[", "datalist", "]"}], "<=", "n"}], ",", 
       RowBox[{"(*", "test", "*)"}], 
       RowBox[{"AppendTo", "[", 
        RowBox[{"datalist", ",", "next"}], "]"}], ",", 
       RowBox[{"(*", "incr", "*)"}], 
       RowBox[{"(*", "body", "*)"}], 
       RowBox[{
        RowBox[{"prev", "=", 
         RowBox[{"Last", "[", "datalist", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Switch", "[", 
         RowBox[{"method", ",", "\"\<euler\>\"", ",", 
          RowBox[{"next", "=", 
           RowBox[{"prev", "+", 
            RowBox[{"h", " ", 
             RowBox[{"(", 
              RowBox[{"f", "@", "prev"}], ")"}]}]}]}], ",", 
          
          RowBox[{"\"\<rk2\>\"", "|", "\"\<heun\>\"", 
           "|", "\"\<improvedeuler\>\""}], ",", 
          RowBox[{
           RowBox[{"r1", "=", 
            RowBox[{"f", "@", "prev"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"r2", "=", 
            RowBox[{"f", "@", 
             RowBox[{"(", 
              RowBox[{"prev", "+", 
               RowBox[{"h", " ", "r1"}]}], ")"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"next", "=", 
            RowBox[{"prev", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"h", "/", "2"}], ")"}], " ", 
              RowBox[{"(", 
               RowBox[{"r1", "+", "r2"}], ")"}]}]}]}]}], ",", "\"\<rk4\>\"", ",", 
          RowBox[{
           RowBox[{"r1", "=", 
            RowBox[{"f", "@", "prev"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"r2", "=", 
            RowBox[{"f", "@", 
             RowBox[{"(", 
              RowBox[{"prev", "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"h", "/", "2"}], ")"}], " ", "r1"}]}], ")"}]}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"r3", "=", 
            RowBox[{"f", "@", 
             RowBox[{"(", 
              RowBox[{"prev", "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"h", "/", "2"}], ")"}], " ", "r2"}]}], ")"}]}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"r4", "=", 
            RowBox[{"f", "@", 
             RowBox[{"(", 
              RowBox[{"prev", "+", 
               RowBox[{"h", " ", "r3"}]}], ")"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"next", "=", 
            RowBox[{"prev", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"h", "/", "6"}], ")"}], " ", 
              RowBox[{"(", 
               RowBox[{"r1", "+", 
                RowBox[{"2", " ", "r2"}], "+", 
                RowBox[{"2", " ", "r3"}], "+", "r4"}], ")"}]}]}]}]}], ",", 
          "_", ",", 
          RowBox[{"(*", 
           RowBox[{
           "default", " ", "to", " ", "Euler", " ", "if", " ", 
            "unrecognized"}], "*)"}], 
          RowBox[{"next", "=", 
           RowBox[{"prev", "+", 
            RowBox[{"h", " ", 
             RowBox[{"(", 
              RowBox[{"f", "@", "prev"}], ")"}]}]}]}]}], "]"}], ";"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "datalist"}]}], 
   "]"}]}], "\n"}], "Input",
