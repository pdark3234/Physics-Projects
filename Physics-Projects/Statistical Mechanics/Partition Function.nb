          RowBox[{"IntegerQ", "[", "probQuery", "]"}], ",", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<P(\>\"", ",", "Bold"}], "]"}], ",", "probQuery", ",", 
