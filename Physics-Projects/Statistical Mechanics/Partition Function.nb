Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "PartitionThermo", "]"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "PartitionThermo", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Method", "->", "\"\<Discrete\>\""}], ",", 
      RowBox[{"DiscreteVariable", "->", "n"}], ",", 
      RowBox[{"QDomain", "->", 
       RowBox[{"{", 
        RowBox[{"q", ",", "0", ",", "Infinity"}], "}"}]}], ",", 
      RowBox[{"PDomain", "->", 
       RowBox[{"{", 
        RowBox[{"p", ",", "0", ",", "Infinity"}], "}"}]}], ",", 
      RowBox[{"NParticles", "->", "1"}], ",", 
      RowBox[{"ProbabilityQuery", "->", "Automatic"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"PartitionThermo", "[", 
   RowBox[{"input_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"(*", 
      RowBox[{"Option", " ", "Inputs"}], "*)"}], 
     RowBox[{
      RowBox[{"method", "=", 
       RowBox[{"OptionValue", "[", "Method", "]"}]}], ",", 
      RowBox[{"n", "=", 
       RowBox[{"OptionValue", "[", "DiscreteVariable", "]"}]}], ",", 
      RowBox[{"qdom", "=", 
       RowBox[{"OptionValue", "[", "QDomain", "]"}]}], ",", 
      RowBox[{"pdom", "=", 
       RowBox[{"OptionValue", "[", "PDomain", "]"}]}], ",", 
      RowBox[{"N", "=", 
       RowBox[{"OptionValue", "[", "NParticles", "]"}]}], ",", 
      RowBox[{"probQuery", "=", 
       RowBox[{"OptionValue", "[", "ProbabilityQuery", "]"}]}], ",", 
      RowBox[{"(*", "Variables", "*)"}], "q", ",", "qmin", ",", "qmax", ",", 
      "p", ",", "pmin", ",", "pmax", ",", "Z", ",", "ZN", ",", "beta", ",", 
      "U", ",", "F", ",", "S", ",", "CV", ",", "Hval", ",", "Gval", ",", 
      "probFunc", ",", "probResult", ",", 
      RowBox[{"(*", 
       RowBox[{"Internal", " ", "Symbols"}], "*)"}], 
      RowBox[{"h", "=", "h"}], ",", 
      RowBox[{"kB", "=", "kB"}], ",", 
      RowBox[{"T", "=", "T"}], ",", 
      RowBox[{"P", "=", "P"}], ",", 
      RowBox[{"V", "=", "V"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"q", ",", "qmin", ",", "qmax"}], "}"}], "=", "qdom"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p", ",", "pmin", ",", "pmax"}], "}"}], "=", "pdom"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"beta", "=", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"kB", " ", "T"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Partition", " ", "Function", " ", "Z"}], "*)"}], 
     RowBox[{"Z", "=", 
      RowBox[{
       RowBox[{"Simplify", "@", 
        RowBox[{"Switch", "[", 
         RowBox[{"method", ",", "\"\<Discrete\>\"", ",", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "beta"}], " ", "input"}], "/.", " ", 
              RowBox[{"n", "->", "i"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], 
          ",", "\"\<Continuous\>\"", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "h"}], ")"}], " ", 
           RowBox[{"Integrate", "[", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "beta"}], " ", "input"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"q", ",", "qmin", ",", "qmax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"p", ",", "pmin", ",", "pmax"}], "}"}], ",", 
             RowBox[{"Assumptions", "->", 
              RowBox[{
               RowBox[{"Element", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"q", ",", "p"}], "}"}], ",", "Reals"}], "]"}], "&&", 
               RowBox[{"q", ">=", "0"}], "&&", 
               RowBox[{"p", ">=", "0"}]}]}]}], "]"}]}], ",", "\"\<Direct\>\"",
           ",", "input", ",", "_", ",", 
          RowBox[{
          "Return", 
           "[", "\"\<Invalid Method: Choose \\\"Discrete\\\", \
\\\"Continuous\\\", or \\\"Direct\\\"\>\"", "]"}]}], "]"}]}], "//", 
       "PowerExpand"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ZN", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"Z", "^", "N"}], "/", 
        RowBox[{"Factorial", "[", "N", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"U", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"Log", "[", "Z", "]"}], ",", "T"}], "]"}]}], "*", 
        RowBox[{"T", "^", "2"}], "*", "kB"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"F", "=", 
