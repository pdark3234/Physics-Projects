      RowBox[{"Simplify", "[", 
       RowBox[{"F", "+", 
        RowBox[{"P", " ", "V"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Probability", " ", "Function"}], "*)"}], 
     RowBox[{"probFunc", "=", 
      RowBox[{"Switch", "[", 
       RowBox[{"method", ",", "\"\<Discrete\>\"", ",", 
        RowBox[{"Function", "[", 
         RowBox[{"i", ",", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "beta"}], " ", "input"}], "/.", " ", 
             RowBox[{"n", "->", "i"}]}], "]"}], "/", "Z"}]}], "]"}], 
        ",", "\"\<Continuous\>\"", ",", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"qq", ",", "pp"}], "}"}], ",", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "beta"}], " ", "input"}], "/.", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"q", "->", "qq"}], ",", 
               RowBox[{"p", "->", "pp"}]}], "}"}]}], "]"}], "/", "Z"}]}], 
         "]"}], ",", "\"\<Direct\>\"", ",", "None"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"probResult", "=", 
      RowBox[{"Switch", "[", 
