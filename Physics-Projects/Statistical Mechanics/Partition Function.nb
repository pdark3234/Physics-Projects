Cell[BoxData[
 TabViewBox[{{1,"\<\"Partition Functions\"\>"->
  PanelBox[
   TagBox[GridBox[{
      {
       StyleBox["\<\"Single Particle Partition Function Z\"\>",
        StripOnInput->False,
        FontSize->16,
        FontWeight->Bold]},
      {
       StyleBox[
        FractionBox[
         SuperscriptBox["\[ExponentialE]", 
          FractionBox[
           RowBox[{"\[Omega]", " ", "\[HBar]"}], 
           RowBox[{"2", " ", "kB", " ", "T"}]]], 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          SuperscriptBox["\[ExponentialE]", 
           FractionBox[
