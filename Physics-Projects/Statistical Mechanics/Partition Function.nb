                 RowBox[{"{", 
                  RowBox[{"i", ",", "m", ",", "Infinity"}], "}"}]}], "]"}]}], 
              "}"}], "]"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"Head", "[", "probQuery", "]"}], "===", "GreaterThan"}], ",", 
