              RowBox[{"\"\<) = \>\"", ",", "Bold"}], "]"}], ",", 
             RowBox[{"probFunc", "[", "probQuery", "]"}]}], "}"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Head", "[", "probQuery", "]"}], "===", "LessThan"}], ",", 
          RowBox[{"With", "[", 
